# ============================================================
# Clawbox — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── Timezone ─────────────────────────────────────────────────
TZ=America/Sao_Paulo

# ── 9Router Settings ─────────────────────────────────────────
# Port exposed on the host for the 9router OpenAI-compatible API
# Default: 20128 — compatible with Claude Code, Cursor, Cline, Copilot
ROUTER_PORT=20128

# ── Hermes Agent Settings ────────────────────────────────────
# Port for the Hermes web dashboard (bound to 127.0.0.1 for safety)
HERMES_DASHBOARD_PORT=4999

# Authentication credentials for the Hermes dashboard (Required by Hermes Agent when exposing ports)
HERMES_DASHBOARD_USERNAME=admin
HERMES_DASHBOARD_PASSWORD=admin

# The API key sent to 9router — any string works for free providers
HERMES_API_KEY=sk-3107ac71f421f497-f3h2xp-f962b882

# Default model Hermes will use via 9router
# Examples (must be supported by a free provider in 9router):
#   claude-3-5-sonnet-20241022   (via free tier)
#   gpt-4o-mini
#   gemini-2.0-flash
HERMES_DEFAULT_MODEL=gemini-2.0-flash

# ── Optional Integrations ────────────────────────────────────
# Telegram Bot Token (leave empty to disable)
TELEGRAM_BOT_TOKEN=

# Discord Bot Token (leave empty to disable)
DISCORD_BOT_TOKEN=
