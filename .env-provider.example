# ============================================================
# Clawbox — Centralized Provider Configuration
# ============================================================
# Este arquivo é a ÚNICA fonte de verdade para URL, chave e modelo
# do provider. Todos os stacks (hermes, openclaw, nanobot) leem daqui.
#
# Para trocar de provider globalmente:
#   1. Edite PROVIDER_BASE_URL, PROVIDER_API_KEY e PROVIDER_MODEL
#   2. Execute `make envs` para propagar para todos os stacks
#
# A chave REAL do 9router é extraída automaticamente pelo
# openclaw-setup.sh via scripts/sync-provider.sh.
# ============================================================

# ── Provider URL ──────────────────────────────────
# Endpoint base do provider (OpenAI-compatible)
PROVIDER_BASE_URL=http://9router:20128/v1

# ── API Key ───────────────────────────────────────
# sk-free-via-9router é aceito pelo 9router como "free access".
# A chave REAL (UUID) é extraída do SQLite do 9router e sobrescrita
# automaticamente pelo openclaw-setup.sh.
PROVIDER_API_KEY=sk-free-via-9router

# ── Model ─────────────────────────────────────────
# Modelo padrão para todos os stacks
PROVIDER_MODEL=gpt-4o-mini
