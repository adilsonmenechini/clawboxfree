# ============================================================
# Clawbox — Nanobot Environment (EXEMPLO)
# ============================================================
# Provider vars (OPENAI_BASE_URL, OPENAI_API_KEY) vêm do
# .env-provider na raiz do projeto.
# Execute `make envs` para propagar as mudanças.
# ============================================================

TZ=America/Sao_Paulo

# ── Portas ─────────────────────────────────────────────────
NANOBOT_GW_HTTP_PORT=8765
NANOBOT_GW_WS_PORT=18790
NANOBOT_API_PORT=8900

# Chave Anthropic (opcional — fallback, não está no .env-provider)
ANTHROPIC_API_KEY=
