# ============================================================
# Clawbox — OpenClaw Environment (EXEMPLO)
# Imagem oficial: ghcr.io/openclaw/openclaw
# Copie para .env e ajuste conforme necessário.
# ============================================================

TZ=America/Sao_Paulo

# Mapeamento de UID/GID pra evitar problema de permissão no bind mount
PUID=1000
PGID=1000

# Nginx Proxy (basic auth)
OPENCLAW_AUTH_USERNAME=admin
OPENCLAW_AUTH_PASSWORD=clawbox-admin

# Secrets (preenchidos automaticamente pelo setup)
ROUTER_9_API_KEY=sk-clawbox-exemplo

