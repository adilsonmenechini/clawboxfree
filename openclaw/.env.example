TZ=America/Sao_Paulo

# LLM via 9router (OpenAI-compatible)
OPENAI_BASE_URL=http://9router:20128/v1
OPENAI_API_KEY=sk-free-via-9router

# Mapeamento de UID/GID pra evitar problema de permissão no bind mount
PUID=1000
PGID=1000
