# ============================================================
# Clawbox — OpenClaw Environment (EXEMPLO)
# Imagem oficial: ghcr.io/openclaw/openclaw
# ============================================================
# Provider vars (ROUTER_9_API_KEY) vêm do .env-provider na raiz.
# Execute `make envs` para propagar as mudanças.
# ROUTER_9_API_KEY é sobrescrita pelo setup com a chave real
# extraída do 9router.
# ============================================================

TZ=America/Sao_Paulo

PUID=1000
PGID=1000

# Nginx Proxy (basic auth)
OPENCLAW_AUTH_USERNAME=admin
OPENCLAW_AUTH_PASSWORD=clawbox-admin

# Gateway token (preenchido automaticamente pelo setup)
OPENCLAW_GATEWAY_TOKEN=clawbox-init-token
